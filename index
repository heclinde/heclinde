<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CV IT - Hector Solalinde</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600&display=swap');

        :root {
            --bg-deep: #0B0A0D;
            --bg-card: #1C1B20;
            --primary-v: #9D5CFF;
            --primary-soft: rgba(157, 92, 255, 0.1);
            --blue-pill-bg: #E6F1FB;
            --blue-pill-text: #185FA5;
            --text-main: #F4F4F5;
            --text-sub: #A1A1AA;
            --border: #2D2C33;
            --radius: 12px;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background-color: var(--bg-deep);
            color: var(--text-main);
            font-family: 'Inter', sans-serif;
            line-height: 1.6;
        }

        .cv-wrap {
            max-width: 1000px;
            margin: 0 auto;
            padding: 2rem 1.5rem;
        }

        /* NAVEGACIÓN */
        .cv-nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 1.5rem;
            background: rgba(28, 27, 32, 0.8);
            backdrop-filter: blur(12px);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            margin-bottom: 2.5rem;
            position: sticky;
            top: 15px;
            z-index: 100;
        }

        .cv-nav-logo {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-weight: 800;
            color: var(--primary-v);
        }

        /* HERO - CON BOTONES */
        .cv-hero {
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 1rem;
            align-items: center;
            padding: 1.5rem;
            background: linear-gradient(145deg, #1C1B20 0%, #0B0A0D 100%);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            margin-bottom: 1.5rem;
        }

        .cv-hero h1 {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-weight: 800;
            font-size: 3.5rem;
            line-height: 1.1;
            margin-bottom: 1.5rem;
            color: #FFF;
        }

        .cv-hero-sub {
            font-size: 16px;
            color: var(--text-sub);
            max-width: 600px;
            margin-bottom: 2rem;
        }

        /* ESTILO DE BOTONES */
        .hero-btns {
            display: flex;
            gap: 12px;
            margin-top: 10px;
        }

        .btn-primary {
            background: var(--primary-v);
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 8px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: 0.3s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-primary:hover {
            background: #8646E6;
            transform: translateY(-2px);
        }

        .btn-secondary {
            background: transparent;
            color: white;
            border: 1px solid var(--border);
            padding: 12px 24px;
            border-radius: 8px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: 0.3s;
            text-decoration: none;
        }

        .btn-secondary:hover {
            background: rgba(255,255,255,0.05);
            border-color: var(--text-sub);
        }

        .cv-avatar {    padding: 0;  
    overflow: hidden;    
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: -215px;
    
}

.avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
            width: 200px;
            height: 200px;
            border-radius: 50%;
            background: var(--primary-soft);
            border: 2px solid var(--primary-v);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--primary-v);
            box-shadow: 0 0 30px rgba(157, 92, 255, 0.2);
        }

        /* GRID Y TARJETAS */
        .cv-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
        .cv-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.8rem; margin-bottom: 1.5rem; }
        .cv-card-full { grid-column: span 2; }

        .cv-section-title {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-sub);
            margin-bottom: 1.5rem;
            padding-bottom: 0.8rem;
            border-bottom: 1px solid var(--border);
        }

        /* HABILIDADES */
        .skill-group-label { font-size: 13px; color: var(--text-sub); margin: 15px 0 12px; }
        .cv-skills-grid { display: flex; flex-wrap: wrap; gap: 10px; }
        .cv-skill-chip { font-size: 12px; padding: 6px 14px; border-radius: 8px; background: #252329; border: 1px solid var(--border); color: var(--text-main); }
        .cv-skill-chip.highlight { background: var(--primary-soft); border-color: var(--primary-v); }

        /* EXPERIENCIA */
        .exp-header { display: flex; justify-content: space-between; align-items: flex-start; }
        .exp-role { font-weight: 700; font-size: 1.1rem; color: #FFF; }
        .exp-date { font-size: 11px; color: var(--text-sub); padding: 4px 12px; border-radius: 20px; border: 1px solid var(--border); background: rgba(255,255,255,0.05); }
        .exp-list { list-style: none; padding-left: 0; margin-top: 1rem; }
        .exp-list li { font-size: 14px; color: var(--text-sub); margin-bottom: 10px; display: flex; gap: 10px; }
        .exp-list li::before { content: "—"; color: var(--text-sub); }
        .tech-pills { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 1.5rem; }
        .tech-pill { font-size: 11px; font-weight: 600; padding: 3px 12px; border-radius: 20px; background: var(--blue-pill-bg); color: var(--blue-pill-text); border: 1px solid #B5D4F4; }

        /* EDUCACIÓN Y RESUMEN */
        .edu-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 1rem; }
        .edu-tag { font-size: 12px; padding: 6px 14px; border-radius: 8px; background: #252329; border: 1px solid var(--border); color: var(--text-main); }
        .resumen-list { display: flex; flex-direction: column; gap: 15px; margin-top: 1.5rem; }
        .resumen-item { display: flex; align-items: center; gap: 12px; }
        .resumen-icon { width: 42px; height: 42px; background: var(--blue-pill-bg); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 20px; border: 1px solid #B5D4F4; }
        .resumen-info p:first-child { font-size: 11px; color: var(--text-sub); text-transform: uppercase; }
        .resumen-info p:last-child { font-size: 14px; font-weight: 600; color: #FFF; }

        .cv-footer { text-align: center; padding: 3rem; color: var(--text-sub); font-size: 12px; border-top: 1px solid var(--border); margin-top: 2rem; }

        @media (max-width: 768px) {
            .cv-grid, .cv-hero { grid-template-columns: 1fr; }
            .cv-card-full { grid-column: span 1; }
            .cv-hero { text-align: center; padding: 2rem; }
            .cv-avatar { margin: 0 auto; order: -1; }
            .hero-btns { justify-content: center; }
        }
    </style>
</head>
